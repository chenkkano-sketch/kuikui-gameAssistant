<Window x:Class="KuikuiGameAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="盔盔游戏助手"
        Icon="/Assets/AppIcon.ico"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Border x:Name="WindowFrameBorder"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Background="{DynamicResource WindowBackgroundBrush}"
            SnapsToDevicePixels="True">
        <Grid ClipToBounds="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="WindowBackgroundStart" Color="{DynamicResource SurfaceColor}" Offset="0" />
                    <GradientStop x:Name="WindowBackgroundMiddle" Color="{DynamicResource WindowBackgroundColor}" Offset="0.52" />
                    <GradientStop x:Name="WindowBackgroundEnd" Color="{DynamicResource SurfaceMutedColor}" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Ellipse x:Name="BackgroundGlowPrimary"
                     Width="420"
                     Height="220"
                     Margin="-130,-92,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="{DynamicResource AccentSoftBrush}"
                     Opacity="0.72"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="58" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse x:Name="BackgroundGlowSecondary"
                     Width="360"
                     Height="220"
                     Margin="0,110,-120,0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Fill="{DynamicResource AccentCyanBrush}"
                     Opacity="0.18"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="64" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse x:Name="BackgroundGlowTertiary"
                     Width="300"
                     Height="190"
                     Margin="260,0,0,-110"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Bottom"
                     Fill="{DynamicResource AccentVioletBrush}"
                     Opacity="0.14"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="64" />
                </Ellipse.Effect>
            </Ellipse>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Background="{DynamicResource TitleBarBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Image Width="28" Height="28"
                           Source="/Assets/AppIcon.png"
                           ToolTip="盔盔游戏助手"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="盔盔游戏助手" Margin="10,0,0,0" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Border Margin="12,0,0,0"
                            Padding="8,3"
                            CornerRadius="8"
                            Background="{DynamicResource AccentSoftBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="Game Assistant"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="Minimize_Click" ToolTip="最小化">
                        <Grid Width="14" Height="14">
                            <Rectangle Width="12" Height="1.2" Fill="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="Maximize_Click" ToolTip="最大化">
                        <Grid Width="14" Height="14">
                            <Rectangle Width="11" Height="11" Stroke="{DynamicResource TextPrimaryBrush}"
                                       StrokeThickness="1.2" Fill="Transparent"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="Close_Click" ToolTip="关闭">
                        <Grid Width="14" Height="14">
                            <Line X1="3" Y1="3" X2="11" Y2="11" Stroke="{DynamicResource TextPrimaryBrush}"
                                  StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="11" Y1="3" X2="3" Y2="11" Stroke="{DynamicResource TextPrimaryBrush}"
                                  StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="196" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,14,0,0">
                            <Button x:Name="DashboardNav" Tag="Dashboard" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE9D2;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="实时监控" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="HardwareNav" Tag="Hardware" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE950;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="硬件信息" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="CaptureNav" Tag="Capture" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE722;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="截图录屏" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="OverlayNav" Tag="Overlay" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="悬浮窗" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="FilterNav" Tag="Filter" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE790;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="游戏滤镜" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Button x:Name="SettingsNav"
                                Grid.Row="1"
                                Tag="Settings"
                                Width="42"
                                Height="42"
                                MinWidth="0"
                                Padding="0"
                                Margin="10,0,0,16"
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}"
                                Click="Nav_Click"
                                ToolTip="设置">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="Root"
                                            Background="Transparent"
                                            CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="&#xE713;" Style="{StaticResource IconTextStyle}" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Background="{DynamicResource ContentBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="112" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="32,22,32,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <Border Width="112"
                                    Padding="10,4"
                                    CornerRadius="10"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource AccentSoftBrush}">
                                <TextBlock Text="CONTROL PANEL"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock x:Name="PageTitle" Text="实时监控" Margin="0,7,0,0" FontSize="28" FontWeight="Bold" />
                            <TextBlock x:Name="PageSubtitle" Text="帧率、负载、温度和内存状态" Margin="0,6,0,0"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button x:Name="OverlayButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="{DynamicResource AccentBrush}"
                                    Click="Overlay_Click"
                                    ToolTip="打开或关闭悬浮监控窗">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" Foreground="{DynamicResource PrimaryButtonForegroundBrush}" Margin="0,0,8,0" />
                                    <TextBlock x:Name="OverlayButtonText" Text="悬浮窗" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ContentControl x:Name="PageHost" Grid.Row="1" Margin="32,0,32,32" />
                </Grid>
            </Grid>

            <Border x:Name="ToastHost"
                    Grid.RowSpan="2"
                    Panel.ZIndex="20"
                    MinWidth="150"
                    MaxWidth="320"
                    Padding="13,10"
                    Margin="0,0,30,30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    IsHitTestVisible="False"
                    Opacity="0"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="4"
                                      Opacity="0.18" />
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTransform" Y="10" />
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE73E;"
                               FontFamily="{StaticResource IconFont}"
                               FontSize="13"
                               Foreground="{DynamicResource StatusOkBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="ToastText"
                               Grid.Column="1"
                               Margin="9,0,0,0"
                               Text="设置已保存"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
