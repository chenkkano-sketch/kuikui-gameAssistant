<Window x:Class="KuikuiGameAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="盔盔游戏助手"
        Icon="/Assets/AppIcon.ico"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Background="{StaticResource TitleBarBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Image Width="28" Height="28"
                           Source="/Assets/AppIcon.png"
                           ToolTip="盔盔游戏助手"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="盔盔游戏助手" Margin="10,0,0,0" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="Minimize_Click" ToolTip="最小化">
                        <Grid Width="14" Height="14">
                            <Rectangle Width="12" Height="1.2" Fill="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="Maximize_Click" ToolTip="最大化">
                        <Grid Width="14" Height="14">
                            <Rectangle Width="11" Height="11" Stroke="{StaticResource TextPrimaryBrush}"
                                       StrokeThickness="1.2" Fill="Transparent"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource ChromeButtonStyle}" Click="Close_Click" ToolTip="关闭">
                        <Grid Width="14" Height="14">
                            <Line X1="3" Y1="3" X2="11" Y2="11" Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            <Line X1="11" Y1="3" X2="3" Y2="11" Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="224" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,18,0,0">
                            <Button x:Name="DashboardNav" Tag="Dashboard" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE9D2;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="实时监控" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="HardwareNav" Tag="Hardware" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE950;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="硬件信息" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="CaptureNav" Tag="Capture" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE722;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="截图录屏" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="OverlayNav" Tag="Overlay" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="悬浮窗" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="FilterNav" Tag="Filter" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE790;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="游戏滤镜" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <Button x:Name="SettingsNav" Tag="Settings" Style="{StaticResource NavButtonStyle}" Click="Nav_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE713;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="设置" FontSize="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2" Margin="14,0,14,18" Padding="12" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="采集状态" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Ellipse Width="8" Height="8" Fill="#FF16A34A" VerticalAlignment="Center" />
                                    <TextBlock Text="传感器服务运行中" Margin="8,0,0,0" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Background="{StaticResource WindowBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="92" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="28,18,28,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="PageTitle" Text="实时监控" FontSize="26" FontWeight="SemiBold" />
                            <TextBlock x:Name="PageSubtitle" Text="帧率、负载、温度和内存状态" Margin="0,6,0,0"
                                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="Refresh_Click"
                                    ToolTip="刷新当前页面">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconTextStyle}" Margin="0,0,8,0" />
                                    <TextBlock Text="刷新" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="OverlayButton" Style="{StaticResource PrimaryButtonStyle}" Click="Overlay_Click" ToolTip="打开或关闭悬浮监控窗">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" Foreground="White" Margin="0,0,8,0" />
                                    <TextBlock x:Name="OverlayButtonText" Text="悬浮窗" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ContentControl x:Name="PageHost" Grid.Row="1" Margin="28,0,28,28" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
