<UserControl x:Class="KuikuiGameAssistant.Views.CapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <Border Padding="22" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Margin="0,0,10,0"
                                Padding="20"
                                CornerRadius="14"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Width="52"
                                        Height="52"
                                        CornerRadius="15"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource SurfaceBrush}">
                                    <TextBlock Text="&#xE722;"
                                               Style="{StaticResource IconTextStyle}"
                                               FontSize="22"
                                               Foreground="{DynamicResource AccentBrush}" />
                                </Border>
                                <StackPanel Grid.Row="1" Margin="0,20,0,18">
                                    <TextBlock Text="区域截图" FontSize="24" FontWeight="Bold" />
                                    <TextBlock Text="PNG / 编辑完成复制到剪切板"
                                               Margin="0,6,0,0"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                                <Button Grid.Row="2"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="44"
                                        Click="Screenshot_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE722;" Style="{StaticResource IconTextStyle}" Foreground="{DynamicResource PrimaryButtonForegroundBrush}" Margin="0,0,8,0" />
                                        <TextBlock Text="开始截图" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="10,0,0,0"
                                Padding="20"
                                CornerRadius="14"
                                Background="{DynamicResource SurfaceMutedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Width="52"
                                        Height="52"
                                        CornerRadius="15"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource SurfaceBrush}">
                                    <TextBlock Text="&#xE714;"
                                               Style="{StaticResource IconTextStyle}"
                                               FontSize="22"
                                               Foreground="{DynamicResource AccentVioletBrush}" />
                                </Border>
                                <StackPanel Grid.Row="1" Margin="0,20,0,18">
                                    <TextBlock Text="录制桌面" FontSize="24" FontWeight="Bold" />
                                    <TextBlock Text="MP4 / H.264 / 主显示器"
                                               Margin="0,6,0,0"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                                <Button x:Name="RecordButton"
                                        Grid.Row="2"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="44"
                                        Click="Record_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE714;" Style="{StaticResource IconTextStyle}" Foreground="{DynamicResource PrimaryButtonForegroundBrush}" Margin="0,0,8,0" />
                                        <TextBlock x:Name="RecordButtonText" Text="开始录屏" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Height="0" Visibility="Collapsed">
                    <TextBlock x:Name="ScreenshotStatus" Text="就绪" />
                    <TextBlock x:Name="RecordStatus" Text="就绪" />
                </Grid>

                <Border Margin="0,16,0,0" Padding="20" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="保存路径" FontSize="18" FontWeight="Bold" />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="76" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="截图" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding ScreenshotFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="38"
                                    Width="66"
                                    MinWidth="0"
                                    Margin="10,0,0,0"
                                    Click="BrowseScreenshotFolder_Click">
                                <TextBlock Text="浏览" />
                            </Button>

                            <TextBlock Grid.Row="1" Text="视频" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding RecordingFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="38"
                                    Width="66"
                                    MinWidth="0"
                                    Margin="10,0,0,0"
                                    Click="BrowseRecordingFolder_Click">
                                <TextBlock Text="浏览" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Padding="20" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="录制参数" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="输出质量、码率和缩放比例"
                                   Margin="0,5,0,16"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="86" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="42" />
                                <RowDefinition Height="42" />
                                <RowDefinition Height="42" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="帧率" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="FrameRateCombo"
                                      Grid.Column="1"
                                      Height="34"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RecordingFrameRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Text="码率" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="BitrateCombo"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Height="34"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RecordingBitrateKbps, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Text="分辨率" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="ScaleCombo"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Height="34"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RecordingScalePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="20" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="录制轨道" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="录屏时同步写入的画面和音频信息"
                                   Margin="0,5,0,16"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <UniformGrid Columns="1">
                            <CheckBox Content="HDR 画面"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      IsChecked="{Binding RecordHdr, Mode=TwoWay}"
                                      Margin="0,0,0,14" />
                            <CheckBox Content="系统声音"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      IsChecked="{Binding RecordSystemAudio, Mode=TwoWay}"
                                      Margin="0,0,0,14" />
                            <CheckBox Content="麦克风"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      IsChecked="{Binding RecordMicrophone, Mode=TwoWay}"
                                      Margin="0,0,0,14" />
                            <CheckBox Content="显示鼠标"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      IsChecked="{Binding ShowMouseCursorInRecording, Mode=TwoWay}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
