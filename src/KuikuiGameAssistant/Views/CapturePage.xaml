<UserControl x:Class="KuikuiGameAssistant.Views.CapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*" />
                <ColumnDefinition Width="1.18*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <Border Padding="20" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="截图" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="区域 PNG / 编辑完成复制到剪切板"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Click="Screenshot_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE722;" Style="{StaticResource IconTextStyle}" Foreground="{DynamicResource PrimaryButtonForegroundBrush}" Margin="0,0,8,0" />
                                    <TextBlock Text="区域截图" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Margin="0,18,0,0" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="8" Padding="12">
                            <TextBlock x:Name="ScreenshotStatus"
                                       Text="就绪"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Padding="20" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="保存路径" FontSize="18" FontWeight="SemiBold" />
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="48" />
                                <RowDefinition Height="48" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="截图" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding ScreenshotFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="36"
                                    Width="62"
                                    MinWidth="0"
                                    Margin="10,0,0,0"
                                    Click="BrowseScreenshotFolder_Click">
                                <TextBlock Text="浏览" />
                            </Button>

                            <TextBlock Grid.Row="1" Text="视频" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding RecordingFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="36"
                                    Width="62"
                                    MinWidth="0"
                                    Margin="10,0,0,0"
                                    Click="BrowseRecordingFolder_Click">
                                <TextBlock Text="浏览" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Padding="20" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="录屏" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="MP4 / H.264 · 主显示器"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <Button x:Name="RecordButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Click="Record_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE714;" Style="{StaticResource IconTextStyle}" Foreground="{DynamicResource PrimaryButtonForegroundBrush}" Margin="0,0,8,0" />
                                    <TextBlock x:Name="RecordButtonText" Text="开始录屏" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Margin="0,18,0,0" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="8" Padding="12">
                            <TextBlock x:Name="RecordStatus"
                                       Text="就绪"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Padding="20" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="画质设定" FontSize="18" FontWeight="SemiBold" />
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="46" />
                                <RowDefinition Height="46" />
                                <RowDefinition Height="46" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="帧率" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="FrameRateCombo"
                                      Grid.Column="1"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RecordingFrameRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Text="码率" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="BitrateCombo"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RecordingBitrateKbps, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Text="分辨率" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="ScaleCombo"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding RecordingScalePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="20" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="录制开关" FontSize="18" FontWeight="SemiBold" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <CheckBox Content="HDR"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      IsChecked="{Binding RecordHdr, Mode=TwoWay}"
                                      Margin="0,0,14,12" />
                            <CheckBox Content="系统声音"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      IsChecked="{Binding RecordSystemAudio, Mode=TwoWay}"
                                      Margin="0,0,0,12" />
                            <CheckBox Content="麦克风"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      IsChecked="{Binding RecordMicrophone, Mode=TwoWay}"
                                      Margin="0,0,14,0" />
                            <CheckBox Content="显示鼠标"
                                      Style="{StaticResource SwitchCheckBoxStyle}"
                                      IsChecked="{Binding ShowMouseCursorInRecording, Mode=TwoWay}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
