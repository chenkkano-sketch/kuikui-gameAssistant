<Window x:Class="KuikuiGameAssistant.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/AppIcon.ico"
        Width="560"
        Height="58"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Border x:Name="RootBorder"
            Background="#E80B1220"
            BorderThickness="0"
            CornerRadius="8"
            Padding="10"
            MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
        <Grid>
            <Grid x:Name="HorizontalPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HFpsLabel" Text="FPS" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock x:Name="HFpsText" Text="--" Foreground="White" FontSize="20"
                               FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HCpuLabel" Text="CPU" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock x:Name="HCpuText" Text="--%" Foreground="White" FontSize="18"
                               FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HGpuLabel" Text="GPU" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock x:Name="HGpuText" Text="--%" Foreground="White" FontSize="18"
                               FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HMemoryLabel" Text="MEM" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock x:Name="HMemoryText" Text="--%" Foreground="White" FontSize="18"
                               FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HCpuTempLabel" Text="CPU" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock x:Name="HCpuTempText" Text="--℃" Foreground="#FFE5E7EB" FontSize="16"
                               FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HGpuTempLabel" Text="GPU" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock x:Name="HGpuTempText" Text="--℃" Foreground="#FFE5E7EB" FontSize="16"
                               FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Grid x:Name="VerticalPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VFpsLabel" Text="FPS" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="VFpsText" Text="--" Foreground="White" FontSize="22"
                               FontWeight="SemiBold" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VCpuLabel" Text="CPU" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="VCpuText" Text="--%" Foreground="White" FontSize="18"
                               FontWeight="SemiBold" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VGpuLabel" Text="GPU" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="VGpuText" Text="--%" Foreground="White" FontSize="18"
                               FontWeight="SemiBold" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="3" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VMemoryLabel" Text="MEM" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="VMemoryText" Text="--%" Foreground="White" FontSize="18"
                               FontWeight="SemiBold" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="4" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VCpuTempLabel" Text="CPU" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="VCpuTempText" Text="--℃" Foreground="#FFE5E7EB" FontSize="16"
                               FontWeight="SemiBold" HorizontalAlignment="Right" />
                </Grid>
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VGpuTempLabel" Text="GPU" Foreground="#FF9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" x:Name="VGpuTempText" Text="--℃" Foreground="#FFE5E7EB" FontSize="16"
                               FontWeight="SemiBold" HorizontalAlignment="Right" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
