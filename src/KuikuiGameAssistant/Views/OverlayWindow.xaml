<Window x:Class="KuikuiGameAssistant.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Assets/AppIcon.ico"
        Width="660"
        Height="58"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Border x:Name="RootBorder"
            Background="{DynamicResource SurfaceBrush}"
            BorderThickness="0"
            CornerRadius="8"
            Padding="6"
            MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
        <Grid>
            <ItemsControl x:Name="HorizontalPanel"
                          ItemsSource="{Binding Metrics}"
                          VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding Visibility}">
                            <TextBlock Text="{Binding Label}"
                                       Foreground="{Binding LabelBrush}"
                                       FontSize="{Binding LabelFontSize}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Value}"
                                       Foreground="{Binding ValueBrush}"
                                       FontSize="{Binding ValueFontSize}"
                                       FontWeight="SemiBold"
                                       Margin="7,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="VerticalPanel"
                          ItemsSource="{Binding Metrics}"
                          Visibility="Collapsed">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding Visibility}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}"
                                       Foreground="{Binding LabelBrush}"
                                       FontSize="{Binding LabelFontSize}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Value}"
                                       Foreground="{Binding ValueBrush}"
                                       FontSize="{Binding ValueFontSize}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>
