<UserControl x:Class="KuikuiGameAssistant.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="快捷键" FontSize="17" FontWeight="SemiBold" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="46" />
                            <RowDefinition Height="46" />
                            <RowDefinition Height="46" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="截图" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                 LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                 Text="{Binding ScreenshotHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                        <TextBlock Grid.Row="1" Text="开始/停止录屏" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                 LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                 Text="{Binding RecordingHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                        <TextBlock Grid.Row="2" Text="打开/关闭悬浮窗" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                 LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                 Text="{Binding OverlayHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                    </Grid>
                    <TextBlock Text="点击输入框后直接按新的组合键；Esc 取消，Backspace 清空。"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="录屏" FontSize="17" FontWeight="SemiBold" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="56" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="42" />
                            <RowDefinition Height="42" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="帧率" FontSize="13" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" Minimum="5" Maximum="60"
                                Value="{Binding RecordingFrameRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding RecordingFrameRate, StringFormat={}{0} FPS}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />

                        <TextBlock Grid.Row="1" Text="录制缩放" FontSize="13" VerticalAlignment="Center" />
                        <Slider Grid.Row="1" Grid.Column="1" Minimum="25" Maximum="100"
                                Value="{Binding RecordingScalePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding RecordingScalePercent, StringFormat={}{0}%}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="行为" FontSize="17" FontWeight="SemiBold" />
                    <CheckBox Content="开机自动启动"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                              Margin="0,14,0,10" />
                    <CheckBox Content="启动后自动最小化到托盘"
                              IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}"
                              Margin="0,0,0,10" />
                    <CheckBox Content="截图后打开保存目录"
                              IsChecked="{Binding OpenScreenshotFolder, Mode=TwoWay}"
                              Margin="0,0,0,10" />
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="自动更新" FontSize="17" FontWeight="SemiBold" />
                    <CheckBox Content="启动时自动检查 GitHub Release"
                              IsChecked="{Binding AutoCheckUpdates, Mode=TwoWay}"
                              Margin="0,14,0,10" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="仓库" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding GitHubRepository, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <Button x:Name="CheckUpdateButton"
                                Grid.Column="2"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="36"
                                Width="88"
                                MinWidth="0"
                                Margin="8,0,0,0"
                                Click="CheckUpdate_Click">
                            <TextBlock Text="检查更新" />
                        </Button>
                    </Grid>
                    <TextBlock x:Name="UpdateStatusText"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="文件保存" FontSize="17" FontWeight="SemiBold" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="68" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="46" />
                            <RowDefinition Height="46" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="截图目录" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding ScreenshotFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Height="36" Width="60" MinWidth="0" Margin="8,0,0,0"
                                Click="BrowseScreenshotFolder_Click">
                            <TextBlock Text="浏览" />
                        </Button>

                        <TextBlock Grid.Row="1" Text="视频目录" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding RecordingFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Height="36" Width="60" MinWidth="0" Margin="8,0,0,0"
                                Click="BrowseRecordingFolder_Click">
                            <TextBlock Text="浏览" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="FPS 采集" FontSize="17" FontWeight="SemiBold" />
                    <CheckBox Content="启用 PresentMon FPS 采集"
                              IsChecked="{Binding EnablePresentMon, Mode=TwoWay}"
                              Margin="0,14,0,10" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="68" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="程序路径" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding PresentMonPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Height="36" Width="60" MinWidth="0" Margin="8,0,0,0"
                                Click="BrowsePresentMon_Click">
                            <TextBlock Text="浏览" />
                        </Button>
                    </Grid>
                    <TextBlock Text="可留空；程序会搜索 PATH、输出目录和 tools\PresentMon。启用后会读取真实 FPS / FrameTime。"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
