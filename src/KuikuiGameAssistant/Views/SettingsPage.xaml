<UserControl x:Class="KuikuiGameAssistant.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="外观" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="默认跟随 Windows 应用主题，系统切换浅色或深色时会同步刷新。"
                                   Margin="0,6,20,0"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox x:Name="ThemeModeComboBox"
                              Grid.Column="1"
                              Height="36"
                              VerticalAlignment="Center"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              Background="{DynamicResource InputBackgroundBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              DisplayMemberPath="Title"
                              SelectedValuePath="Mode"
                              SelectedValue="{Binding ThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="快捷键" FontSize="17" FontWeight="SemiBold" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="46" />
                            <RowDefinition Height="46" />
                            <RowDefinition Height="46" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="截图" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                 LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                 Text="{Binding ScreenshotHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                        <TextBlock Grid.Row="1" Text="开始/停止录屏" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                 LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                 Text="{Binding RecordingHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                        <TextBlock Grid.Row="2" Text="打开/关闭悬浮窗" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                 LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                 Text="{Binding OverlayHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                    </Grid>
                    <TextBlock Text="点击输入框后直接按新的组合键；Esc 取消，Backspace 清空。"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="行为" FontSize="17" FontWeight="SemiBold" />
                    <CheckBox Content="开机自动启动"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                              Margin="0,14,0,10" />
                    <CheckBox Content="启动后自动最小化到托盘"
                              IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}"
                              Margin="0,0,0,10" />
                    <CheckBox Content="点击关闭按钮时最小化到托盘"
                              IsChecked="{Binding CloseToTray, Mode=TwoWay}"
                              Margin="0,0,0,10" />
                    <CheckBox Content="截图后打开保存目录"
                              IsChecked="{Binding OpenScreenshotFolder, Mode=TwoWay}"
                              Margin="0,0,0,10" />
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="自动更新" FontSize="17" FontWeight="SemiBold" />
                    <CheckBox Content="启动时自动检查 GitHub Release"
                              IsChecked="{Binding AutoCheckUpdates, Mode=TwoWay}"
                              Margin="0,14,0,10" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="更新源：GitHub Releases"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="API 受限时可直接打开 Release 或复制固定下载直链。"
                                       Margin="0,4,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="36"
                                Width="88"
                                MinWidth="0"
                                Margin="8,0,0,0"
                                Click="OpenRepository_Click">
                            <TextBlock Text="GitHub" />
                        </Button>
                        <Button Grid.Column="2"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="36"
                                Width="88"
                                MinWidth="0"
                                Margin="8,0,0,0"
                                Click="OpenLatestRelease_Click">
                            <TextBlock Text="Release" />
                        </Button>
                        <Button Grid.Column="3"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="36"
                                Width="96"
                                MinWidth="0"
                                Margin="8,0,0,0"
                                Click="CopyDownloadLink_Click">
                            <TextBlock Text="复制直链" />
                        </Button>
                        <Button x:Name="CheckUpdateButton"
                                Grid.Column="4"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="36"
                                Width="88"
                                MinWidth="0"
                                Margin="8,0,0,0"
                                Click="CheckUpdate_Click">
                            <TextBlock Text="检查更新" />
                        </Button>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Height="34"
                                MinWidth="88"
                                Click="OpenBlog_Click">
                            <TextBlock Text="盔盔博客" />
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Height="34"
                                MinWidth="88"
                                Margin="8,0,0,0"
                                Click="OpenTavern_Click">
                            <TextBlock Text="留言酒馆" />
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="UpdateStatusText"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <ProgressBar x:Name="UpdateProgressBar"
                                 Margin="0,10,0,0"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="文件保存" FontSize="17" FontWeight="SemiBold" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="68" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="46" />
                            <RowDefinition Height="46" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="截图目录" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding ScreenshotFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Height="36" Width="60" MinWidth="0" Margin="8,0,0,0"
                                Click="BrowseScreenshotFolder_Click">
                            <TextBlock Text="浏览" />
                        </Button>

                        <TextBlock Grid.Row="1" Text="视频目录" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding RecordingFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Height="36" Width="60" MinWidth="0" Margin="8,0,0,0"
                                Click="BrowseRecordingFolder_Click">
                            <TextBlock Text="浏览" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="18" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="FPS 采集" FontSize="17" FontWeight="SemiBold" />
                    <CheckBox Content="启用 FPS 后台引擎（安装版会自动启动 KuikuiTelemetryService）"
                              IsChecked="{Binding EnablePresentMon, Mode=TwoWay}"
                              Margin="0,14,0,10" />
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Height="34"
                            MinWidth="118"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"
                            Click="RestartAsAdmin_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" Style="{StaticResource IconTextStyle}" Margin="0,0,8,0" />
                            <TextBlock Text="管理员重启" />
                        </StackPanel>
                    </Button>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="68" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="程序路径" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding PresentMonPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Height="36" Width="60" MinWidth="0" Margin="8,0,0,0"
                                Click="BrowsePresentMon_Click">
                            <TextBlock Text="浏览" />
                        </Button>
                    </Grid>
                    <TextBlock Text="安装版会自动安装并启动 FPS 后台服务；程序路径仅用于开发或便携模式诊断。"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
