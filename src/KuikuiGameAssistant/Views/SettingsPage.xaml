<UserControl x:Class="KuikuiGameAssistant.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <Border Padding="20" MinHeight="326" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="外观与行为" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="窗口主题、启动方式和关闭行为。"
                                   Margin="0,5,0,16"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="46" />
                                <RowDefinition Height="46" />
                                <RowDefinition Height="46" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="主题" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="ThemeModeComboBox"
                                      Grid.Column="1"
                                      Height="38"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Title"
                                      SelectedValuePath="Mode"
                                      SelectedValue="{Binding ThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1" Text="背景" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="BackgroundModeComboBox"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Height="38"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Title"
                                      SelectedValuePath="Mode"
                                      SelectedValue="{Binding BackgroundMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2" Text="字体" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="FontModeComboBox"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Height="38"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource InputBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      DisplayMemberPath="Title"
                                      SelectedValuePath="Mode"
                                      SelectedValue="{Binding FontMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <UniformGrid Columns="1" Margin="0,18,0,0">
                            <CheckBox Content="开机自动启动"
                                      IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                                      Margin="0,0,0,12" />
                            <CheckBox Content="启动后自动最小化到托盘"
                                      IsChecked="{Binding StartMinimizedToTray, Mode=TwoWay}"
                                      Margin="0,0,0,12" />
                            <CheckBox Content="点击关闭按钮时最小化到托盘"
                                      IsChecked="{Binding CloseToTray, Mode=TwoWay}"
                                      Margin="0,0,0,12" />
                            <CheckBox Content="截图后打开保存目录"
                                      IsChecked="{Binding OpenScreenshotFolder, Mode=TwoWay}" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Padding="20" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="文件保存" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="截图和录屏文件的默认输出位置。"
                                   Margin="0,5,0,16"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="截图" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="{Binding ScreenshotFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Height="38" Width="62" MinWidth="0" Margin="8,0,0,0" Click="BrowseScreenshotFolder_Click">
                                <TextBlock Text="浏览" />
                            </Button>

                            <TextBlock Grid.Row="1" Text="视频" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="{Binding RecordingFolder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" Height="38" Width="62" MinWidth="0" Margin="8,0,0,0" Click="BrowseRecordingFolder_Click">
                                <TextBlock Text="浏览" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Padding="20" MinHeight="326" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="快捷键" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="点击输入框后直接按新的组合键；Esc 取消，Backspace 清空。"
                                   Margin="0,5,0,16"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="128" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                                <RowDefinition Height="50" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="截图" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                     LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                     Text="{Binding ScreenshotHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                            <TextBlock Grid.Row="1" Text="开始/停止录屏" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                     LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                     Text="{Binding RecordingHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                            <TextBlock Grid.Row="2" Text="悬浮窗热键" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <CheckBox Grid.Row="2" Grid.Column="1"
                                      Content="启用打开/关闭悬浮窗快捷键"
                                      IsChecked="{Binding OverlayHotkeyEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Text="打开/关闭悬浮窗" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     IsEnabled="{Binding OverlayHotkeyEnabled}"
                                     GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                     LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                     Text="{Binding OverlayHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                            <TextBlock Grid.Row="4" Text="眩晕缓解热键" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <CheckBox Grid.Row="4" Grid.Column="1"
                                      Content="启用一键开关 3D 眩晕缓解"
                                      IsChecked="{Binding MotionSicknessHotkeyEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                            <TextBlock Grid.Row="5" Text="开关眩晕缓解" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Row="5" Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     IsEnabled="{Binding MotionSicknessHotkeyEnabled}"
                                     GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus"
                                     LostKeyboardFocus="HotkeyTextBox_LostKeyboardFocus"
                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                     Text="{Binding MotionSicknessHotkeyText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="20" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="自动更新" FontSize="18" FontWeight="Bold" />
                                <TextBlock Text="GitHub Releases 更新源和下载入口。"
                                           Margin="0,5,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <CheckBox Content="启动时检查"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding AutoCheckUpdates, Mode=TwoWay}" />
                        </Grid>

                        <UniformGrid Columns="4" Margin="0,18,0,14">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Height="38" Margin="0,0,8,0" Click="OpenRepository_Click">
                                <TextBlock Text="GitHub" />
                            </Button>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Height="38" Margin="0,0,8,0" Click="OpenLatestRelease_Click">
                                <TextBlock Text="Release" />
                            </Button>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Height="38" Margin="0,0,8,0" Click="CopyDownloadLink_Click">
                                <TextBlock Text="复制直链" />
                            </Button>
                            <Button x:Name="CheckUpdateButton" Style="{StaticResource PrimaryButtonStyle}" Height="38" Click="CheckUpdate_Click">
                                <TextBlock Text="检查更新" />
                            </Button>
                        </UniformGrid>

                        <TextBlock x:Name="UpdateStatusText"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <ProgressBar x:Name="UpdateProgressBar"
                                     Margin="0,12,0,0"
                                     Height="6"
                                     Minimum="0"
                                     Maximum="100"
                                     Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border Padding="20" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="关于作者" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="项目主页、反馈和留言入口。"
                                   Margin="0,5,0,16"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Height="38" MinWidth="96" Click="OpenBlog_Click">
                                <TextBlock Text="盔盔博客" />
                            </Button>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Height="38" MinWidth="96" Margin="10,0,0,0" Click="OpenTavern_Click">
                                <TextBlock Text="留言酒馆" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
