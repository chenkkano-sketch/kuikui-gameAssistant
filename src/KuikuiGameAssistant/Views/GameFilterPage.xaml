<UserControl x:Class="KuikuiGameAssistant.Views.GameFilterPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="全屏色彩滤镜" FontSize="17" FontWeight="SemiBold" />
                            <CheckBox Content="启用色彩"
                                      HorizontalAlignment="Right"
                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="108" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44" />
                                <RowDefinition Height="44" />
                                <RowDefinition Height="44" />
                                <RowDefinition Height="44" />
                                <RowDefinition Height="44" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="亮度" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="-100" Maximum="100"
                                    Value="{Binding Brightness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="2" Text="{Binding Brightness, StringFormat={}{0:0}}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Text="对比度" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="-100" Maximum="100"
                                    Value="{Binding Contrast, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Contrast, StringFormat={}{0:0}}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Text="灰度" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding Grayscale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding Grayscale, StringFormat={}{0:0}%}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="3" Text="饱和度" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="200"
                                    Value="{Binding Saturation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Saturation, StringFormat={}{0:0}%}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="4" Text="色调" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Row="4" Grid.Column="1" Minimum="-180" Maximum="180"
                                    Value="{Binding Hue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Hue, StringFormat={}{0:0}°}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="屏幕暗角" FontSize="17" FontWeight="SemiBold" />
                            <CheckBox Content="启用暗角"
                                      HorizontalAlignment="Right"
                                      IsChecked="{Binding VignetteEnabled, Mode=TwoWay}" />
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="108" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44" />
                                <RowDefinition Height="44" />
                                <RowDefinition Height="44" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="颜色" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding VignetteColorHex, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <Border x:Name="VignetteColorPreview"
                                    Grid.Column="2"
                                    Width="34"
                                    Height="24"
                                    CornerRadius="6"
                                    HorizontalAlignment="Right"
                                    Background="{StaticResource SurfaceMutedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" />

                            <TextBlock Grid.Row="1" Text="亮暗" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding VignetteIntensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding VignetteIntensity, StringFormat={}{0:0}%}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Text="羽化" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding VignetteFeather, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding VignetteFeather, StringFormat={}{0:0}%}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="预设" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="保存当前滤镜参数，之后可随时读档。"
                                   Margin="0,6,0,12"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox x:Name="PresetNameBox"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Text="我的沉浸滤镜" />
                        <ComboBox x:Name="PresetComboBox"
                                  ItemsSource="{Binding Presets}"
                                  DisplayMemberPath="Name"
                                  Height="36"
                                  Margin="0,10,0,0" />
                        <UniformGrid Columns="2" Margin="0,12,0,0">
                            <Button Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,6,8" Click="SavePreset_Click">
                                <TextBlock Text="保存预设" />
                            </Button>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,8" Click="LoadPreset_Click">
                                <TextBlock Text="读取预设" />
                            </Button>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Click="DeletePreset_Click">
                                <TextBlock Text="删除预设" />
                            </Button>
                            <Button Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,0" Click="Reset_Click">
                                <TextBlock Text="重置滤镜" />
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Padding="18" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="界面主题" FontSize="17" FontWeight="SemiBold" />
                        <CheckBox x:Name="DarkModeCheckBox"
                                  Content="深色模式"
                                  Margin="0,14,0,0"
                                  Checked="DarkModeCheckBox_Changed"
                                  Unchecked="DarkModeCheckBox_Changed" />
                    </StackPanel>
                </Border>

                <Border Padding="18" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="状态" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock x:Name="FilterStatusText"
                                   Text="滤镜未启用"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
