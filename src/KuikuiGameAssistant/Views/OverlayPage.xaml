<UserControl x:Class="KuikuiGameAssistant.Views.OverlayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SwatchButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#26000000" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.74" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="348" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <TextBlock Text="布局" FontSize="15" FontWeight="SemiBold" />
                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <RadioButton x:Name="HorizontalLayoutRadio" Content="横版" Margin="0,0,10,0"
                                         Checked="HorizontalLayout_Checked" />
                            <RadioButton x:Name="VerticalLayoutRadio" Content="竖版"
                                         Checked="VerticalLayout_Checked" />
                        </UniformGrid>
                        <TextBlock Text="{Binding CurrentSizeText}" Margin="0,10,0,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="背景透明度" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding BackgroundOpacityText}" HorizontalAlignment="Right"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                        <Slider Minimum="0.2" Maximum="1" Value="{Binding BackgroundOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="0.01" SmallChange="0.01" LargeChange="0.02"
                                IsMoveToPointEnabled="True" Margin="0,10,0,0" />

                        <Grid Margin="0,16,0,0">
                            <TextBlock Text="数字字号" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FontSizeText}" HorizontalAlignment="Right"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                        <Slider Minimum="12" Maximum="28" Value="{Binding FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,10,0,0" />

                        <Grid Margin="0,16,0,0">
                            <TextBlock Text="标签字号" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LabelFontSizeText}" HorizontalAlignment="Right"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                        <Slider Minimum="9" Maximum="18" Value="{Binding LabelFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="横版尺寸" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding HorizontalSizeText}" HorizontalAlignment="Right"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="宽度" Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Slider Minimum="420" Maximum="760" Value="{Binding HorizontalWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="10" IsSnapToTickEnabled="True" />
                        <TextBlock Text="高度" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Slider Minimum="46" Maximum="96" Value="{Binding HorizontalHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="2" IsSnapToTickEnabled="True" />
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="竖版尺寸" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding VerticalSizeText}" HorizontalAlignment="Right"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="宽度" Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Slider Minimum="108" Maximum="220" Value="{Binding VerticalWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="4" IsSnapToTickEnabled="True" />
                        <TextBlock Text="高度" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Slider Minimum="190" Maximum="360" Value="{Binding VerticalHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="5" IsSnapToTickEnabled="True" />
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="颜色" FontSize="15" FontWeight="SemiBold" />

                        <TextBlock Text="背景色" Margin="0,10,0,8" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <WrapPanel>
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF0B1220" Tag="#0B1220" Click="BackgroundSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF111827" Tag="#111827" Click="BackgroundSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF172554" Tag="#172554" Click="BackgroundSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF052E2B" Tag="#052E2B" Click="BackgroundSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF3B1D0B" Tag="#3B1D0B" Click="BackgroundSwatch_Click" />
                        </WrapPanel>

                        <TextBlock Text="数字颜色" Margin="0,6,0,8" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <WrapPanel>
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFFDE68A" Tag="#FDE68A" Click="FontSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFFFFFFF" Tag="#FFFFFF" Click="FontSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFBAE6FD" Tag="#BAE6FD" Click="FontSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFBBF7D0" Tag="#BBF7D0" Click="FontSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFFECACA" Tag="#FECACA" Click="FontSwatch_Click" />
                        </WrapPanel>

                        <TextBlock Text="标签颜色" Margin="0,6,0,8" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <WrapPanel>
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF86EFAC" Tag="#86EFAC" Click="LabelSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF9CA3AF" Tag="#9CA3AF" Click="LabelSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF93C5FD" Tag="#93C5FD" Click="LabelSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFFDBA74" Tag="#FDBA74" Click="LabelSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFD8B4FE" Tag="#D8B4FE" Click="LabelSwatch_Click" />
                        </WrapPanel>

                        <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,10,0,0" HorizontalAlignment="Left"
                                Click="Reset_Click" Content="恢复默认" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Padding="20" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="可视化预览" FontSize="17" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="主屏幕" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding PrimaryResolutionText}" Margin="8,0,0,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Margin="0,16,0,0" Background="#FF0F172A" CornerRadius="8" ClipToBounds="True">
                    <Viewbox Stretch="Uniform" Margin="18">
                        <Grid Width="760" Height="430">
                            <Border Background="#FF111827" CornerRadius="8" BorderBrush="#2DFFFFFF" BorderThickness="1" />
                            <Grid Margin="18">
                                <TextBlock Text="{Binding PrimaryResolutionText}" Foreground="#FF64748B" FontSize="14"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                            </Grid>

                            <Border x:Name="PreviewOverlay"
                                    Width="{Binding CurrentWidth}"
                                    Height="{Binding CurrentHeight}"
                                    Background="{Binding BackgroundBrush}"
                                    BorderThickness="0"
                                    CornerRadius="8"
                                    Padding="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Grid x:Name="PreviewHorizontalPanel">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.05*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1.05*" />
                                            <ColumnDefinition Width="1.05*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="FPS" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Text="144" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="CPU" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Text="36%" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="GPU" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Text="82%" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="MEM" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Text="61%" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="CPU" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Text="72℃" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="GPU" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Text="68℃" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid x:Name="PreviewVerticalPanel" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="FPS" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="144" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid Grid.Row="1" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="CPU" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="36%" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid Grid.Row="2" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="GPU" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="82%" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid Grid.Row="3" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="MEM" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="61%" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid Grid.Row="4" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="CPU" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="72℃" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        </Grid>
                                        <Grid Grid.Row="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="GPU" Foreground="{Binding LabelBrush}" FontSize="{Binding LabelFontSize}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="68℃" Foreground="{Binding FontBrush}" FontSize="{Binding FontSize}"
                                                       FontWeight="SemiBold" HorizontalAlignment="Right" />
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Viewbox>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
