<UserControl x:Class="KuikuiGameAssistant.Views.OverlayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SwatchButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.74" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="348" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <TextBlock Text="布局" FontSize="15" FontWeight="SemiBold" />
                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <RadioButton x:Name="HorizontalLayoutRadio"
                                         Content="横版"
                                         Margin="0,0,10,0"
                                         Checked="HorizontalLayout_Checked" />
                            <RadioButton x:Name="VerticalLayoutRadio"
                                         Content="竖版"
                                         Checked="VerticalLayout_Checked" />
                        </UniformGrid>
                        <TextBlock Text="{Binding CurrentSizeText}"
                                   Margin="0,10,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <CheckBox Content="固定悬浮窗（鼠标穿透）"
                                  IsChecked="{Binding IsClickThroughEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Checked="ClickThroughToggle_Changed"
                                  Unchecked="ClickThroughToggle_Changed"
                                  Margin="0,12,0,0" />
                        <CheckBox Content="仅全屏/无边框全屏游戏时显示"
                                  IsChecked="{Binding OnlyShowInFullscreen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Checked="FullscreenVisibilityToggle_Changed"
                                  Unchecked="FullscreenVisibilityToggle_Changed"
                                  Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <TextBlock Text="显示模块" FontSize="15" FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{Binding Metrics}" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Label}"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Checked="MetricToggle_Changed"
                                              Unchecked="MetricToggle_Changed"
                                              Margin="0,0,8,8" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="背景透明度" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding BackgroundOpacityText}"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <Slider Minimum="0"
                                Maximum="1"
                                Value="{Binding BackgroundOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="0.01"
                                SmallChange="0.01"
                                LargeChange="0.02"
                                IsMoveToPointEnabled="True"
                                Margin="0,10,0,0" />

                        <Grid Margin="0,16,0,0">
                            <TextBlock Text="数字字号" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FontSizeText}"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <Slider Minimum="12"
                                Maximum="28"
                                Value="{Binding FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,10,0,0" />

                        <Grid Margin="0,16,0,0">
                            <TextBlock Text="标签字号" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding LabelFontSizeText}"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <Slider Minimum="9"
                                Maximum="18"
                                Value="{Binding LabelFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="横版尺寸" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding HorizontalSizeText}"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="宽度" Margin="0,10,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Slider Minimum="180"
                                Maximum="880"
                                Value="{Binding HorizontalWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True" />
                        <TextBlock Text="高度" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Slider Minimum="30"
                                Maximum="96"
                                Value="{Binding HorizontalHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True" />
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,10">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="竖版尺寸" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding VerticalSizeText}"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </Grid>
                        <TextBlock Text="宽度" Margin="0,10,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Slider Minimum="88"
                                Maximum="220"
                                Value="{Binding VerticalWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="4"
                                IsSnapToTickEnabled="True" />
                        <TextBlock Text="高度" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Slider Minimum="96"
                                Maximum="440"
                                Value="{Binding VerticalHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True" />
                    </StackPanel>
                </Border>

                <Border Padding="14" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="颜色" FontSize="15" FontWeight="SemiBold" />

                        <TextBlock Text="背景色" Margin="0,10,0,8" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <WrapPanel>
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF0B1220" Tag="#0B1220" Click="BackgroundSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF111827" Tag="#111827" Click="BackgroundSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF172554" Tag="#172554" Click="BackgroundSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF052E2B" Tag="#052E2B" Click="BackgroundSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF3B1D0B" Tag="#3B1D0B" Click="BackgroundSwatch_Click" />
                        </WrapPanel>

                        <TextBlock Text="数字颜色" Margin="0,6,0,8" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <WrapPanel>
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFFDE68A" Tag="#FDE68A" Click="FontSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFFFFFFF" Tag="#FFFFFF" Click="FontSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFBAE6FD" Tag="#BAE6FD" Click="FontSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFBBF7D0" Tag="#BBF7D0" Click="FontSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFFECACA" Tag="#FECACA" Click="FontSwatch_Click" />
                        </WrapPanel>

                        <TextBlock Text="标签颜色" Margin="0,6,0,8" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <WrapPanel>
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF86EFAC" Tag="#86EFAC" Click="LabelSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF9CA3AF" Tag="#9CA3AF" Click="LabelSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FF93C5FD" Tag="#93C5FD" Click="LabelSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFFDBA74" Tag="#FDBA74" Click="LabelSwatch_Click" />
                            <Button Style="{StaticResource SwatchButtonStyle}" Background="#FFD8B4FE" Tag="#D8B4FE" Click="LabelSwatch_Click" />
                        </WrapPanel>

                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                Click="Reset_Click"
                                Content="恢复默认" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Padding="20" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="可视化预览" FontSize="17" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="主屏幕" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding PrimaryResolutionText}"
                                   Margin="8,0,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Margin="0,16,0,0" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="8" ClipToBounds="True">
                    <Viewbox Stretch="Uniform" Margin="18">
                        <Grid Width="760" Height="430">
                            <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                            <Grid Margin="18">
                                <TextBlock Text="{Binding PrimaryResolutionText}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="14"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom" />
                            </Grid>

                            <Border x:Name="PreviewOverlay"
                                    Width="{Binding CurrentWidth}"
                                    Height="{Binding CurrentHeight}"
                                    Background="{Binding BackgroundBrush}"
                                    BorderThickness="0"
                                    CornerRadius="8"
                                    Padding="6"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <ItemsControl x:Name="PreviewHorizontalPanel"
                                                  ItemsSource="{Binding Metrics}"
                                                  VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Center">
                                                    <StackPanel.Style>
                                                        <Style TargetType="{x:Type StackPanel}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="{Binding DataContext.LabelBrush, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                               FontSize="{Binding DataContext.LabelFontSize, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding PreviewValue}"
                                                               Foreground="{Binding DataContext.FontBrush, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                               FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                               FontWeight="SemiBold"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ItemsControl x:Name="PreviewVerticalPanel"
                                                  ItemsSource="{Binding Metrics}"
                                                  Visibility="Collapsed">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.Style>
                                                        <Style TargetType="{x:Type Grid}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="42" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="{Binding DataContext.LabelBrush, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                               FontSize="{Binding DataContext.LabelFontSize, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding PreviewValue}"
                                                               Foreground="{Binding DataContext.FontBrush, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                               FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Viewbox>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
